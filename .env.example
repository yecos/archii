# =============================================================================
# ArchiFlow v2.0 — Variables de Entorno
# =============================================================================
# Copia este archivo a .env.local y configura los valores reales.
# Las variables marcadas [OBLIGATORIO] son necesarias para que el sistema funcione.
# Las marcadas [OPCIONAL] tienen valores por defecto o son para features especificas.
# =============================================================================

# --- FIREBASE ---
# Firebase Client esta hardcoded en src/app/layout.tsx (CDN).
# Estas variables solo se usan server-side en firebase-admin.ts.
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=archiflow-c2855 (ya tiene fallback hardcoded)

# --- IA / LLM (OpenAI-compatible) ---
# OBLIGATORIO para el asistente IA. Soporta OpenAI, Gemini y DeepSeek.
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1  # Cambiar para Gemini o DeepSeek
# AI_MODEL=gpt-4o-mini  # Modelos: gpt-4o-mini, gemini-2.0-flash, deepseek-chat

# --- WHATSAPP CLOUD API ---
# OBLIGATORIO para notificaciones por WhatsApp.
# Configurar en: https://developers.facebook.com/apps/
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_API_VERSION=v25.0  # OPCIONAL: version de la Meta Graph API

# --- MICROSOFT AZURE / ONEDRIVE ---
# OBLIGATORIO si se usa integracion con OneDrive.
NEXT_PUBLIC_MS_CLIENT_ID=
# AZURE_CLIENT_SECRET=  # OBLIGATORIO para refresh de tokens
# AZURE_CLIENT_ID=      # OPCIONAL: override server-side del client ID

# --- FIREBASE ADMIN (Server-side) ---
# FIREBASE_ADMIN_CREDENTIALS=  # JSON string con service account. Si no se configura,
#                              # se usa Vercel Application Default Credentials (ADC).

# --- ADMIN ---
# ADMIN_EMAIL=yecos11@gmail.com  # OPCIONAL: email del administrador principal.
#                                # Por defecto: yecos11@gmail.com (hardcoded en api-auth.ts)
