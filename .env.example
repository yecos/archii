# ============================================
# ArchiFlow v2.0.0 — Environment Variables
# ============================================
# Copy this file as .env.local and fill in your values.

# --- Firebase ---
# These are automatically configured in Firebase Console for Vercel deployment.
# For local dev, set them in .env.local:
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server-side only — used in API routes)
# Base64-encoded service account JSON for Firebase Admin SDK.
# Generate with: echo -n "$(cat service-account.json)" | base64
FIREBASE_ADMIN_CREDENTIALS=

# --- AI Providers ---
OPENAI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
# Optional: custom base URL for OpenAI-compatible endpoints (e.g., Azure OpenAI proxy)
OPENAI_BASE_URL=
# AI model identifier — defaults to 'groq' if not set. Options: 'groq', 'openai'
AI_MODEL=

# --- WhatsApp Business API ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
# WhatsApp API version (e.g., 'v18.0', 'v19.0')
WHATSAPP_API_VERSION=v18.0

# --- Microsoft OneDrive ---
# Configured via Azure Portal. The redirect URI is handled in AuthContext.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
NEXT_PUBLIC_MS_CLIENT_ID=

# --- App ---
# Production URL — update to your custom domain or Vercel project URL
NEXT_PUBLIC_APP_URL=https://archii.vercel.app
